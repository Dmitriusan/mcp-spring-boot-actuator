{
  "name": "mcp-spring-boot-actuator",
  "version": "0.1.8",
  "description": "MCP server for Spring Boot Actuator analysis — health, metrics, environment, and bean diagnostics",
  "mcpName": "io.github.dmitriusan/mcp-spring-boot-actuator",
  "main": "build/index.js",
  "bin": {
    "mcp-spring-boot-actuator": "build/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "build/**/*.js",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai",
    "claude",
    "anthropic",
    "spring-boot",
    "spring",
    "actuator",
    "java",
    "health-check",
    "metrics",
    "monitoring",
    "diagnostics"
  ],
  "author": "Dmytro Lisnichenko",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dmitriusan/mcp-spring-boot-actuator"
  },
  "homepage": "https://github.com/Dmitriusan/mcp-spring-boot-actuator#readme",
  "bugs": {
    "url": "https://github.com/Dmitriusan/mcp-spring-boot-actuator/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
